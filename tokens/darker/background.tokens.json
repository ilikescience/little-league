{
  "$extensions": { "mode": "dark" },
  "color": {
    "$type": "color",
    "background": {
      "surface": {
        "200": { "$value": "{color.core.gray.800}" },
        "300": { "$value": "{color.core.gray.850}" },
        "range-highlight": { "$value": { "colorSpace": "srgb", "components": [0.113725, 0.113725, 0.129412], "alpha": 1, "hex": "#1D1D21" } },
        "400": { "$value": "{color.core.gray.900}" },
        "line-highlight": { "$value": { "colorSpace": "srgb", "components": [0.101961, 0.101961, 0.113725], "alpha": 1, "hex": "#1A1A1D" } },
        "500": { "$value": "{color.core.gray.950}" },
        "shadow": { "$value": "{color.core.gray.950-alpha-33}" },
        "600": { "$value": "{color.core.gray.950}" },
        "scroll-shadow": { "$value": "{color.core.gray.950-alpha-27}" }
      },
      "drop": { "$value": "{color.background.selection.inactive.300}" },
      "badge": { "$value": "{color.core.blue.350}" },
      "debug": { "$value": "{color.core.purple.400}" },
      "danger": { "$value": "{color.core.red.350}" },
      "danger-subtle": { "$value": { "colorSpace": "srgb", "components": [0.258824, 0.160784, 0.164706], "alpha": 1, "hex": "#42292A" } },
      "warning": { "$value": "{color.core.coral.300}" },
      "success": { "$value": "{color.core.green.200}" },
      "success-subtle": { "$value": { "colorSpace": "srgb", "components": [0.196078, 0.231373, 0.192157], "alpha": 1, "hex": "#323B31" } },
      "info": { "$value": "{color.core.blue.350}" },
      "interactive": {
        "base": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0.192157, 0.32549, 0.458824],
            "alpha": 1,
            "hex": "#315375"
          }
        },
        "hover": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0.211765, 0.411765, 0.596078],
            "alpha": 1,
            "hex": "#366998"
          }
        }
      },
      "selection": {
        "active": {
          "500": { "$value": "{color.core.gray.650-alpha-80}" },
          "600": { "$value": "{color.core.gray.900-alpha-80}" }
        },
        "inactive": {
          "300": { "$value": "{color.core.gray.900-alpha-27}" },
          "400": { "$value": "{color.core.gray.650-alpha-27}" },
          "500": { "$value": "{color.core.gray.500-alpha-27}" },
          "600": { "$value": "{color.core.gray.400-alpha-27}" }
        }
      },
      "highlight": {
        "primary": {
          "active": { "$value": "{color.core.gray.500-alpha-47}" },
          "inactive": { "$value": "{color.core.gray.500-alpha-27}" }
        }
      }
    }
  }
}
