{
  "$extensions": {
    "mode": "light"
  },
  "color": {
    "$type": "color",
    "background": {
      "surface": {
        "200": {
          "$value": "{color.core.gray.100}"
        },
        "300": {
          "$value": "{color.core.gray.50}"
        },
        "400": {
          "$value": "{color.core.gray.50}"
        },
        "500": {
          "$value": "{color.core.gray.0}"
        },
        "600": {
          "$value": "{color.core.gray.0}"
        },
        "range-highlight": {
          "$value": {
            "colorSpace": "oklch",
            "components": [
              0.9851035259,
              3.67187446e-8,
              89.87556294
            ],
            "alpha": 1
          }
        },
        "line-highlight": {
          "$value": {
            "colorSpace": "oklch",
            "components": [
              0.9851035259,
              3.67187446e-8,
              89.87556294
            ],
            "alpha": 1
          }
        },
        "shadow": {
          "$value": "{color.core.gray.0-alpha-33}"
        },
        "scroll-shadow": {
          "$value": "{color.core.gray.0-alpha-27}"
        }
      },
      "drop": {
        "$value": "{color.background.selection.inactive.300}"
      },
      "badge": {
        "$value": "{color.core.blue.350}"
      },
      "debug": {
        "$value": "{color.core.purple.400}"
      },
      "danger": {
        "$value": "{color.core.red.350}"
      },
      "danger-subtle": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.9339338685,
            0.02865989069,
            17.6764136
          ],
          "alpha": 1
        }
      },
      "warning": {
        "$value": "{color.core.coral.300}"
      },
      "success": {
        "$value": "{color.core.green.200}"
      },
      "success-subtle": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.9600936643,
            0.01849568825,
            137.7955456
          ],
          "alpha": 1
        }
      },
      "info": {
        "$value": "{color.core.blue.350}"
      },
      "interactive": {
        "base": {
          "$value": {
            "colorSpace": "oklch",
            "components": [
              0.8393637141,
              0.0545727096,
              244.225038
            ],
            "alpha": 1
          }
        },
        "hover": {
          "$value": {
            "colorSpace": "oklch",
            "components": [
              0.7728482395,
              0.08416111045,
              245.8005848
            ],
            "alpha": 1
          }
        }
      },
      "selection": {
        "active": {
          "500": {
            "$value": "{color.core.gray.100-alpha-60}"
          },
          "600": {
            "$value": "{color.core.gray.50-alpha-60}"
          }
        },
        "inactive": {
          "300": {
            "$value": "{color.core.gray.100-alpha-27}"
          },
          "400": {
            "$value": "{color.core.gray.50-alpha-27}"
          },
          "500": {
            "$value": "{color.core.gray.50-alpha-27}"
          },
          "600": {
            "$value": "{color.core.gray.0-alpha-27}"
          }
        }
      },
      "highlight": {
        "primary": {
          "active": {
            "$value": "{color.core.gray.500-alpha-60}"
          },
          "inactive": {
            "$value": "{color.core.gray.500-alpha-27}"
          }
        }
      }
    }
  }
}
