{
  "$extensions": { "mode": "light" },
  "color": {
    "$type": "color",
    "background": {
      "surface": {
        "200": { "$value": "{color.core.gray.100}" },
        "300": { "$value": "{color.core.gray.50}" },
        "range-highlight": { "$value": { "colorSpace": "srgb", "components": [0.980392, 0.980392, 0.980392], "alpha": 1, "hex": "#FAFAFA" } },
        "400": { "$value": "{color.core.gray.50}" },
        "line-highlight": { "$value": { "colorSpace": "srgb", "components": [0.980392, 0.980392, 0.980392], "alpha": 1, "hex": "#FAFAFA" } },
        "500": { "$value": "{color.core.gray.0}" },
        "shadow": { "$value": "{color.core.gray.0-alpha-33}" },
        "600": { "$value": "{color.core.gray.0}" },
        "scroll-shadow": { "$value": "{color.core.gray.0-alpha-27}" }
      },
      "drop": { "$value": "{color.background.selection.inactive.300}" },
      "badge": { "$value": "{color.core.blue.350}" },
      "debug": { "$value": "{color.core.purple.400}" },
      "danger": { "$value": "{color.core.red.350}" },
      "danger-subtle": { "$value": { "colorSpace": "srgb", "components": [0.988235, 0.886275, 0.886275], "alpha": 1, "hex": "#FCE2E2" } },
      "warning": { "$value": "{color.core.coral.300}" },
      "success": { "$value": "{color.core.green.200}" },
      "success-subtle": { "$value": { "colorSpace": "srgb", "components": [0.92549, 0.960784, 0.913725], "alpha": 1, "hex": "#ECF5E9" } },
      "info": { "$value": "{color.core.blue.350}" },
      "interactive": {
        "base": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0.678431, 0.811765, 0.92549],
            "alpha": 1,
            "hex": "#ADCFEC"
          }
        },
        "hover": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0.533333, 0.733333, 0.909804],
            "alpha": 1,
            "hex": "#88BBE8"
          }
        }
      },
      "selection": {
        "active": {
          "500": { "$value": "{color.core.gray.50-alpha-60}" },
          "600": { "$value": "{color.core.gray.100-alpha-60}" }
        },
        "inactive": {
          "300": { "$value": "{color.core.gray.100-alpha-27}" },
          "400": { "$value": "{color.core.gray.50-alpha-27}" },
          "500": { "$value": "{color.core.gray.50-alpha-27}" },
          "600": { "$value": "{color.core.gray.0-alpha-27}" }
        }
      },
      "highlight": {
        "primary": {
          "active": { "$value": "{color.core.gray.500-alpha-60}" },
          "inactive": { "$value": "{color.core.gray.500-alpha-27}" }
        }
      }
    }
  }
}
