{
  "$type": "color",
  "scrollbar": {
    "shadow": {
      "$value": "{color.background.surface.scroll-shadow}",
      "$description": "Scrollbar slider shadow to indicate that the view is scrolled"
    },
    "background": {
      "$value": "{color.background.surface.500}",
      "$description": "Scrollbar track background color"
    }
  },
  "scrollbarSlider": {
    "activeBackground": {
      "$value": "{color.background.highlight.primary.active}",
      "$description": "Scrollbar slider background color when clicked on"
    },
    "background": {
      "$value": "{color.background.highlight.primary.inactive}",
      "$description": "Scrollbar slider background color"
    },
    "hoverBackground": {
      "$value": "{color.background.highlight.primary.active}",
      "$description": "Scrollbar slider background color when hovering"
    }
  }
}
